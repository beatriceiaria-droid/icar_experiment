    <LoopInitiator loopType="TrialHandler" name="VR_trials">
      <Param name="Selected rows" updates="None" val="$random(4)*16" valType="str"/>
      <Param name="conditions" updates="None" val="[OrderedDict([('CATEGORY', 'VR'), ('QUESTION', '900の、9分の1の4分の1の5分の1はなんでしょうか。'), ('ANSWER', np.int64(4)), ('image_file', 'blank.png'), ('has_image', np.int64(0)), ('choice1', 2.0), ('choice2', 3.0), ('choice3', 4.0), ('choice4', 5.0), ('choice5', 6.0), ('choice6', 7.0), ('choice7', 'この中には答えはない'), ('choice8', 'わからない')]), OrderedDict([('CATEGORY', 'VR'), ('QUESTION', '次の単語のうち、ひとつだけ性質が違うものを選んでください。'), ('ANSWER', np.int64(4)), ('image_file', 'blank.png'), ('has_image', np.int64(0)), ('choice1', 'スギ'), ('choice2', 'ヒノキ'), ('choice3', 'マツ'), ('choice4', 'サクラ'), ('choice5', 'シダ'), ('choice6', 'カエデ'), ('choice7', 'どれも一致する'), ('choice8', 'わからない')]), OrderedDict([('CATEGORY', 'VR'), ('QUESTION', '頑固な人の反対は、---人です。'), ('ANSWER', np.int64(1)), ('image_file', 'blank.png'), ('has_image', np.int64(0)), ('choice1', '柔軟な'), ('choice2', '情熱的な'), ('choice3', '平凡な'), ('choice4', '控えめな'), ('choice5', 'おかしな'), ('choice6', 'しつこい'), ('choice7', 'この中には答えはない'), ('choice8', 'わからない')]), OrderedDict([('CATEGORY', 'VR'), ('QUESTION', 'ミシェルは96が好きですが、45は好きではありません。\nまた、540が好きですが、250は好きではありません。\nミシェルはどの数字が好きでしょうか？'), ('ANSWER', np.int64(5)), ('image_file', 'blank.png'), ('has_image', np.int64(0)), ('choice1', 86.0), ('choice2', 93.0), ('choice3', 98.0), ('choice4', 128.0), ('choice5', 132.0), ('choice6', 140.0), ('choice7', 'この中には答えはない'), ('choice8', 'わからない')]), OrderedDict([('CATEGORY', 'VR'), ('QUESTION', 'アダムとメリッサは釣りに出かけて、人あわせて32匹のサケを釣りました。\nメリッサは、アダムの3倍の数のサケを釣りました。\nアダムは何匹のサケを釣りましたか。'), ('ANSWER', np.int64(2)), ('image_file', 'blank.png'), ('has_image', np.int64(0)), ('choice1', '7匹'), ('choice2', '8匹'), ('choice3', '9匹'), ('choice4', '10匹'), ('choice5', '11匹'), ('choice6', '12匹'), ('choice7', 'この中には答えはない'), ('choice8', 'わからない')]), OrderedDict([('CATEGORY', 'VR'), ('QUESTION', 'ザックはマットより背が高く、リチャードはザックより背が低いです。\nこの情報からわかることとして、どれが最も正しいでしょうか。'), ('ANSWER', np.int64(4)), ('image_file', 'blank.png'), ('has_image', np.int64(0)), ('choice1', 'リチャードは\nマットより背が高い'), ('choice2', 'リチャードは\nマットより背が低い'), ('choice3', 'リチャードは\nマットと同じ背の高さである'), ('choice4', 'この情報だけでは\nわからない'), ('choice5', 'リチャードは\nザックより背が高い'), ('choice6', 'ザックは\nマットより背が低い'), ('choice7', 'この中には答えはない'), ('choice8', 'わからない')]), OrderedDict([('CATEGORY', 'VR'), ('QUESTION', 'ジョシュアは12歳で、ジョシュアのお姉さんはその3倍の年齢です。\nジョシュアが23歳のとき、お姉さんは何歳でしょうか。'), ('ANSWER', np.int64(4)), ('image_file', 'blank.png'), ('has_image', np.int64(0)), ('choice1', '1) 35歳'), ('choice2', '39歳'), ('choice3', '44歳'), ('choice4', '47歳'), ('choice5', '53歳'), ('choice6', '57歳'), ('choice7', 'この中には答えはない'), ('choice8', 'わからない')]), OrderedDict([('CATEGORY', 'VR'), ('QUESTION', '１年のうち、6番目の月は何月でしょうか。'), ('ANSWER', np.int64(5)), ('image_file', 'blank.png'), ('has_image', np.int64(0)), ('choice1', '9月'), ('choice2', '7月'), ('choice3', '5月'), ('choice4', '8月'), ('choice5', '6月'), ('choice6', '4月'), ('choice7', 'この中には答えはない'), ('choice8', 'わからない')]), OrderedDict([('CATEGORY', 'VR'), ('QUESTION', '明後日が木曜日の2日前なら、今日は何日でしょうか。'), ('ANSWER', np.int64(6)), ('image_file', 'blank.png'), ('has_image', np.int64(0)), ('choice1', '金曜日'), ('choice2', '月曜日'), ('choice3', '水曜日'), ('choice4', '土曜日'), ('choice5', '火曜日'), ('choice6', '日曜日'), ('choice7', 'この中には答えはない'), ('choice8', 'わからない')]), OrderedDict([('CATEGORY', 'VR'), ('QUESTION', '次の単語のうち、ひとつだけ性質が違うものを選んでください。'), ('ANSWER', np.int64(5)), ('image_file', 'blank.png'), ('has_image', np.int64(0)), ('choice1', 'ブエノスアイレス'), ('choice2', 'メルボルン'), ('choice3', 'シアトル'), ('choice4', 'カイロ'), ('choice5', 'モロッコ'), ('choice6', 'ミラノ'), ('choice7', 'この中には答えはない'), ('choice8', 'わからない')]), OrderedDict([('CATEGORY', 'VR'), ('QUESTION', '「人当たりのよい人」の反対は、次のうちどのタイプの人であるか。\n空欄に最も当てはまる語を選べ。'), ('ANSWER', np.int64(5)), ('image_file', 'blank.png'), ('has_image', np.int64(0)), ('choice1', '怒りっぽい人'), ('choice2', '社交的な人'), ('choice3', '礼儀正しい'), ('choice4', 'いらだっている人'), ('choice5', '控えめな'), ('choice6', '恩知らずな人'), ('choice7', 'どれでもない'), ('choice8', 'わからない')]), OrderedDict([('CATEGORY', 'VR'), ('QUESTION', 'アイザックはジョージより背が低く、フィリップはジョージより背が高いです。\nこの情報からわかることとして、どれが最も正しいでしょうか。'), ('ANSWER', np.int64(1)), ('image_file', 'blank.png'), ('has_image', np.int64(0)), ('choice1', 'フィリップは\nアイザックより背が高い'), ('choice2', 'フィリップは\nアイザックより背が低い'), ('choice3', 'フィリップは\nアイザックと同じ背の高さである'), ('choice4', 'この情報だけでは\nわからない'), ('choice5', 'アイザックは\nジョージより背が高い'), ('choice6', 'ジョージは\nフィリップより背が高い'), ('choice7', 'この中には答えはない'), ('choice8', 'わからない')]), OrderedDict([('CATEGORY', 'VR'), ('QUESTION', '一昨日（おととい）が土曜日の3日後なら、今日は何日でしょう。'), ('ANSWER', np.int64(1)), ('image_file', 'blank.png'), ('has_image', np.int64(0)), ('choice1', '木曜日'), ('choice2', '土曜日'), ('choice3', '水曜日'), ('choice4', '金曜日'), ('choice5', '日曜日'), ('choice6', '火曜日'), ('choice7', 'この中には答えはない'), ('choice8', 'わからない')]), OrderedDict([('CATEGORY', 'VR'), ('QUESTION', '曖昧な状況の反対は、---状況です。'), ('ANSWER', np.int64(3)), ('image_file', 'blank.png'), ('has_image', np.int64(0)), ('choice1', '不審な'), ('choice2', '漠然とした（ぼんやりとした）'), ('choice3', '明白な'), ('choice4', '知的な'), ('choice5', '疑わしい'), ('choice6', '本当の'), ('choice7', 'この中には答えはない'), ('choice8', 'わからない')]), OrderedDict([('CATEGORY', 'VR'), ('QUESTION', '3頭の牛と4羽のニワトリがいます。\n足の数は牛とニワトリ全部であわせて何本でしょうか。'), ('ANSWER', np.int64(3)), ('image_file', 'blank.png'), ('has_image', np.int64(0)), ('choice1', '16本'), ('choice2', '18本'), ('choice3', '20本'), ('choice4', '21本'), ('choice5', '22本'), ('choice6', '24本'), ('choice7', 'この中には答えはない'), ('choice8', 'わからない')]), OrderedDict([('CATEGORY', 'VR'), ('QUESTION', '太陽から数えて4番目の惑星はなんでしょう。'), ('ANSWER', np.int64(5)), ('image_file', 'blank.png'), ('has_image', np.int64(0)), ('choice1', '木星'), ('choice2', '土星'), ('choice3', '冥王星'), ('choice4', '地球'), ('choice5', '火星'), ('choice6', '金星'), ('choice7', 'この中には答えはない'), ('choice8', 'わからない')])]" valType="str"/>
      <Param name="conditionsFile" updates="None" val="conditions_VR.csv" valType="file"/>
      <Param name="endPoints" updates="None" val="[0, 1]" valType="num"/>
      <Param name="isTrials" updates="None" val="True" valType="bool"/>
